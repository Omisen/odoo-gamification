<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_users_form_ond" model="ir.ui.view">
        <field name="name">res.users.form.ond</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='account_security']" position="after">
                <page name="ond_character" string="Character">
                    <group string="Identity">
                        <field name="character_name" placeholder="e.g. Thalindra the Wise"/>
                        <field name="character_class"/>
                    </group>
                    <group string="Progression">
                        <field name="character_level" readonly="1"/>
                        <field name="character_xp" readonly="1"/>
                        <field name="character_xp_next_level"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>